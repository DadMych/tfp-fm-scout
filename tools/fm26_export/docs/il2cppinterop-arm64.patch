+    /// <summary>
+    /// arm64 only: follow chains of tiny forwarding shims to the real function
+    /// body. Il2cpp API exports and some internal entry points are 1-4
+    /// instruction stubs ("b inner" or "cbz x0, ret; b inner"). Hooking a stub
+    /// is fatal on arm64: an inline hook needs 16 bytes, which overwrites
+    /// neighbouring instructions that other code branches into (SIGILL).
+    /// Hooking the branch target instead is safe and preserves the shim's
+    /// guard semantics for callers that go through it.
+    /// </summary>
+    public static IntPtr FollowThunks(IntPtr codeStart)
+    {
+        if (!IsArm64) return codeStart;
+
+        var current = (long)codeStart;
+        for (var depth = 0; depth < 8; depth++)
+        {
+            var ins0 = (uint)Marshal.ReadInt32((IntPtr)current);
+
+            // Pattern 1: unconditional far B as the very first instruction.
+            if ((ins0 & 0xFC000000u) == 0x14000000u)
+            {
+                var imm = (long)(ins0 & 0x03FFFFFFu);
+                if ((imm & 0x02000000) != 0) imm |= ~0x03FFFFFFL;
+                var target = current + (imm << 2);
+                if (Math.Abs(target - current) <= Arm64ShortBranchWindow) break;
+                current = target;
+                continue;
+            }
+
+            // Pattern 2: null-guard shim — CBZ/CBNZ with a short forward target,
+            // immediately followed by an unconditional far B to the body.
+            if ((ins0 & 0x7E000000u) == 0x34000000u)
+            {
+                var guardImm = (long)((ins0 >> 5) & 0x7FFFF);
+                if ((guardImm & 0x40000) != 0) guardImm |= ~0x7FFFFL;
+                var guardTarget = current + (guardImm << 2);
+                var ins1 = (uint)Marshal.ReadInt32((IntPtr)(current + 4));
+                if (guardTarget > current && guardTarget - current <= 16 &&
+                    (ins1 & 0xFC000000u) == 0x14000000u)
+                {
+                    var imm = (long)(ins1 & 0x03FFFFFFu);
+                    if ((imm & 0x02000000) != 0) imm |= ~0x03FFFFFFL;
+                    var target = current + 4 + (imm << 2);
+                    if (Math.Abs(target - (current + 4)) <= Arm64ShortBranchWindow) break;
+                    current = target;
+                    continue;
+                }
+            }
+
+            break;
+        }
+
+        return (IntPtr)current;
+    }
+
+    /// <summary>
+    /// arm64 only: heuristic check that <paramref name="ptr"/> is the start of a
+    /// function rather than a point inside one. Inline-hooking a mid-function
+    /// address is guaranteed-fatal on arm64 (the 16-byte patch overwrites
+    /// instructions that other branches jump into), so callers should skip the
+    /// hook when this returns false. A function start is preceded by an
+    /// instruction that never falls through (RET/B/BR/BRK) or by padding, or
+    /// itself begins with a canonical prologue.
+    /// </summary>
+    public static bool LooksLikeFunctionStart(IntPtr ptr)
+    {
+        if (!IsArm64) return true;
+
+        var first = (uint)Marshal.ReadInt32(ptr);
+        // Canonical prologues: PACIBSP, SUB SP,SP,#imm, STP xN,xM,[SP,#-imm]!
+        if (first == 0xD503237Fu) return true;
+        if ((first & 0xFF8003FFu) == 0xD10003FFu) return true;
+        if ((first & 0xFFC003E0u) == 0xA98003E0u) return true;
+
+        var prev = (uint)Marshal.ReadInt32((IntPtr)((long)ptr - 4));
+        if (prev == 0 || prev == 0xD503201Fu) return true;            // padding / NOP
+        if ((prev & 0xFFFFFC1Fu) == 0xD65F0000u) return true;         // RET
+        if ((prev & 0xFC000000u) == 0x14000000u) return true;         // B (tail call)
+        if ((prev & 0xFFFFFC1Fu) == 0xD61F0000u) return true;         // BR
+        if ((prev & 0xFFE0001Fu) == 0xD4200000u) return true;         // BRK
+
+        return false;
+    }
+
+    /// <summary>
+    /// arm64 only: targets of far unconditional B instructions (tail calls)
+    /// in the function at <paramref name="codeStart"/>. x86 heuristics like
+    /// "GetGenericVirtualMethod is the last jump target" don't hold on arm64,
+    /// where helper BLs can follow the tail call in the instruction stream.
+    /// </summary>
+    public static IEnumerable<IntPtr> TailCallTargets(IntPtr codeStart)
+    {
+        for (var offset = 0; offset < Arm64ScanLimitBytes; offset += 4)
+        {
+            var pc = (long)codeStart + offset;
+            var ins = (uint)Marshal.ReadInt32((IntPtr)pc);
+
+            if (ins == 0 || (ins & 0xFFE0001Fu) == 0xD4200000u) // padding / BRK
+                yield break;
+
+            if ((ins & 0xFFFFFC1Fu) == 0xD65F0000u) // RET
+                yield break;
+
+            if ((ins & 0xFC000000u) == 0x14000000u) // B (not BL)
+            {
+                var imm = (long)(ins & 0x03FFFFFFu);
+                if ((imm & 0x02000000) != 0) imm |= ~0x03FFFFFFL;
+                var target = pc + (imm << 2);
+                if (Math.Abs(target - pc) > Arm64ShortBranchWindow)
+                    yield return (IntPtr)target;
+            }
+        }
+    }
+
+    // ------------------------------------------------------------------
+    // arm64 (AArch64) support. Iced is an x86-only decoder; on Apple
+    // Silicon we decode the fixed-width 4-byte A64 instruction stream
+    // directly. Semantics mirror the x86 implementation above:
+    //   - BL      => call, always yielded
+    //   - B       => unconditional branch; yielded unless it looks like a
+    //                short intra-function jump (x86 impl skips short jmps);
+    //                if it is the first flow control, treat as a tail-call
+    //                thunk and stop (same as x86)
+    //   - RET     => stop unless ignoreRetn
+    //   - BRK / all-zero words => function padding, stop
+    // ------------------------------------------------------------------
+    private const int Arm64ScanLimitBytes = 0x2000;
+
+    // x86 short jmps (skipped by the x86 impl) have a ±127 byte range; use
+    // the same window to filter arm64 intra-function forward/backward hops.
+    private const long Arm64ShortBranchWindow = 0x80;
+
+    private static IEnumerable<IntPtr> JumpTargetsArm64(IntPtr codeStart, bool ignoreRetn)
+    {
+        var firstFlowControl = true;
+
+        for (var offset = 0; offset < Arm64ScanLimitBytes; offset += 4)
+        {
+            var pc = (long)codeStart + offset;
+            var ins = (uint)Marshal.ReadInt32((IntPtr)pc);
+
+            if (ins == 0) // zero padding between functions
+                yield break;
+
+            if ((ins & 0xFFE0001Fu) == 0xD4200000u) // BRK
+                yield break;
+
+            if ((ins & 0xFFFFFC1Fu) == 0xD65F0000u) // RET
+            {
+                if (!ignoreRetn) yield break;
+                firstFlowControl = false;
+                continue;
+            }
+
+            if ((ins & 0x7C000000u) == 0x14000000u) // B (0b000101) / BL (0b100101), imm26
+            {
+                var isBl = (ins & 0x80000000u) != 0;
+                var imm = (long)(ins & 0x03FFFFFFu);
+                if ((imm & 0x02000000) != 0) imm |= ~0x03FFFFFFL; // sign-extend imm26
+                var target = pc + (imm << 2);
+
+                if (isBl)
+                {
+                    yield return (IntPtr)target;
+                }
+                else
+                {
+                    var isShort = Math.Abs(target - pc) <= Arm64ShortBranchWindow;
+                    if (!isShort)
+                    {
+                        yield return (IntPtr)target;
+                        if (firstFlowControl) yield break; // tail-call thunk
+                    }
+                }
+
+                firstFlowControl = false;
+                continue;
+            }
+
+            if ((ins & 0xFFFFFC1Fu) == 0xD61F0000u || // BR
+                (ins & 0xFFFFFC1Fu) == 0xD63F0000u)   // BLR
+            {
+                firstFlowControl = false;
+                continue;
+            }
+
+            if ((ins & 0xFF000010u) == 0x54000000u || // B.cond
+                (ins & 0x7E000000u) == 0x34000000u || // CBZ/CBNZ
+                (ins & 0x7E000000u) == 0x36000000u)   // TBZ/TBNZ
+            {
+                firstFlowControl = false;
+            }
+        }
+    }
+
+    private static IEnumerable<IntPtr> CallAndIndirectTargetsArm64(IntPtr codeStart)
+    {
+        // Mirrors the x86 version: yields call/jump targets plus addresses
+        // materialized into registers (arm64: ADRP+ADD pairs and ADR, the
+        // equivalent of RIP-relative LEA on x86).
+        var adrpValues = new long[32];
+        var adrpValid = new bool[32];
+
+        for (var offset = 0; offset < 1024 * 1024; offset += 4)
+        {
+            var pc = (long)codeStart + offset;
+            var ins = (uint)Marshal.ReadInt32((IntPtr)pc);
+
+            if (ins == 0 || (ins & 0xFFE0001Fu) == 0xD4200000u) // padding / BRK
+                yield break;
+
+            if ((ins & 0xFFFFFC1Fu) == 0xD65F0000u) // RET
+                yield break;
+
+            if ((ins & 0x7C000000u) == 0x14000000u) // B / BL
+            {
+                var imm = (long)(ins & 0x03FFFFFFu);
+                if ((imm & 0x02000000) != 0) imm |= ~0x03FFFFFFL;
+                yield return (IntPtr)(pc + (imm << 2));
+                continue;
+            }
+
+            if ((ins & 0x9F000000u) == 0x90000000u) // ADRP
+            {
+                var rd = (int)(ins & 0x1F);
+                var immLo = (long)((ins >> 29) & 0x3);
+                var immHi = (long)((ins >> 5) & 0x7FFFF);
+                var imm = (immHi << 2) | immLo;
+                if ((imm & 0x100000) != 0) imm |= ~0x1FFFFFL; // sign-extend imm21
+                adrpValues[rd] = (pc & ~0xFFFL) + (imm << 12);
+                adrpValid[rd] = true;
+                continue;
+            }
+
+            if ((ins & 0x9F000000u) == 0x10000000u) // ADR
+            {
+                var immLo = (long)((ins >> 29) & 0x3);
+                var immHi = (long)((ins >> 5) & 0x7FFFF);
+                var imm = (immHi << 2) | immLo;
+                if ((imm & 0x100000) != 0) imm |= ~0x1FFFFFL;
+                yield return (IntPtr)(pc + imm);
+                continue;
+            }
+
+            if ((ins & 0xFF800000u) == 0x91000000u) // ADD (immediate, 64-bit, no shift or LSL#12)
+            {
+                var rn = (int)((ins >> 5) & 0x1F);
+                if (adrpValid[rn])
+                {
+                    var imm12 = (long)((ins >> 10) & 0xFFF);
+                    if (((ins >> 22) & 1) != 0) imm12 <<= 12;
+                    yield return (IntPtr)(adrpValues[rn] + imm12);
+                    var rd = (int)(ins & 0x1F);
+                    adrpValid[rd] = rd == rn;
+                }
+                continue;
+            }
+        }
+    }
 }
