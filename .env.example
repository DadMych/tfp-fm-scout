# Copy to .env and fill in real values. See docs/16-hosted-deployment.md.

# Neon Postgres pooled connection string (Neon console → Connect → Pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Neon direct connection for migrations (host without -pooler).
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth.js session encryption secret: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (console.cloud.google.com → Credentials → OAuth client ID, type "Web").
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: public site URL for Auth.js callbacks (Vercel sets this automatically with trustHost).
AUTH_URL="http://localhost:3000"
